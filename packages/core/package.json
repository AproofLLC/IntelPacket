{
  "name": "@intelpacket/core",
  "version": "0.1.0",
  "description": "Deterministic structured-data packetization, replay verification, deduplication, compaction, and integrity engine for JSON-like structured systems.",
  "author": "Aproof LLC",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "prepublishOnly": "pnpm run typecheck && pnpm test && pnpm run build",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx benchmarks/compression-bench.ts",
    "bench:realistic": "tsx benchmarks/realistic-bench.ts",
    "bench:advanced": "tsx benchmarks/advanced/advanced-core-bench.ts",
    "bench:50x": "tsx benchmarks/engine-50x-bench.ts",
    "datasets:realistic": "node benchmarks/datasets/realistic/generate-fixtures.mjs",
    "datasets:build": "node benchmarks/datasets/build.mjs",
    "example:basic": "tsx examples/basic-json.ts",
    "example:telemetry": "tsx examples/telemetry.ts",
    "example:state": "tsx examples/state-stream.ts",
    "example:replay": "tsx examples/replay.ts"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "keywords": [
    "canonical-json",
    "compression",
    "deduplication",
    "delta-encoding",
    "deterministic",
    "hashing",
    "normalization",
    "replay"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AproofLLC/IntelPacket.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/AproofLLC/IntelPacket/issues"
  },
  "homepage": "https://github.com/AproofLLC/IntelPacket/tree/main/packages/core#readme",
  "publishConfig": {
    "access": "public"
  }
}
